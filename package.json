{
  "name": "libraryxxx",
  "private": true,
  "version": "1.1.10",
  "description": "Personal video game library launcher",
  "author": "Kyaxuu",
  "main": "electron/dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npx tsc -p tsconfig.electron.json && cross-env NODE_ENV=development electron .",
    "build": "npx rimraf dist && tsc -b && vite build",
    "build:electron": "npx tsc -p tsconfig.electron.json",
    "package": "npm run build && npm run build:electron && electron-builder",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.gamelibrary.launcher",
    "productName": "Game Library Launcher",
    "npmRebuild": true,
    "directories": {
      "output": "build-dist"
    },
    "publish": [
      {
        "provider": "github"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/dist/**/*"
    ],
    "extraMetadata": {
      "main": "electron/dist/main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "installerHeaderIcon": "build/icon.ico",
      "include": "build/installer.nsh",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "Game Library Launcher",
      "artifactName": "GameLibraryLauncher-Setup-${version}.exe",
      "uninstallDisplayName": "Game Library Launcher",
      "deleteAppDataOnUninstall": false
    }
  }
}
